{
  "name": "@servlyui/number-input",
  "version": "0.1.1",
  "description": "Servly numeric input with units, presets, suggestions, and draggable value control",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core.d.ts",
      "import": "./dist/core.js",
      "require": "./dist/core.cjs",
      "default": "./dist/core.js"
    },
    "./adapters/antd": {
      "types": "./dist/adapters/antd.d.ts",
      "import": "./dist/adapters/antd.js",
      "require": "./dist/adapters/antd.cjs",
      "default": "./dist/adapters/antd.js"
    },
    "./haptics": {
      "types": "./dist/haptics.d.ts",
      "import": "./dist/haptics.js",
      "default": "./dist/haptics.js"
    },
    "./assets/haptics/*": "./dist/assets/haptics/*",
    "./styles.css": "./dist/styles.css"
  },
  "files": [
    "dist",
    "README.md",
    "AGENTS.readme"
  ],
  "sideEffects": [
    "./dist/styles.css"
  ],
  "scripts": {
    "build": "node scripts/clean-dist.mjs && tsup && node scripts/copy-styles.mjs",
    "dev": "tsup --watch",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:dry-run": "npm pack --dry-run"
  },
  "keywords": [
    "servly",
    "react",
    "number-input",
    "tailwind",
    "css-units",
    "component"
  ],
  "author": "Servly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/servlyapp/servlyui.git",
    "directory": "packages/number-input"
  },
  "homepage": "https://github.com/servlyapp/servlyui/tree/main/packages/number-input#readme",
  "bugs": {
    "url": "https://github.com/servlyapp/servlyui/issues"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "peerDependencies": {
    "antd": "^5.0.0",
    "draggable-number-input": "^0.0.9",
    "lucide-react": ">=1.24.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-icons": ">=4.0.0"
  },
  "peerDependenciesMeta": {
    "antd": {
      "optional": true
    },
    "draggable-number-input": {
      "optional": true
    },
    "lucide-react": {
      "optional": true
    },
    "react-icons": {
      "optional": true
    }
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.2.79",
    "@types/react-dom": "^18.2.25",
    "antd": "^5.21.0",
    "draggable-number-input": "^0.0.9",
    "jsdom": "^26.0.0",
    "lucide-react": "^1.24.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-icons": "^4.12.0",
    "tsup": "^8.5.1",
    "typescript": "^5.5.4",
    "vitest": "^2.1.8"
  }
}

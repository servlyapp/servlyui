{
  "name": "servlyui",
  "version": "0.0.0",
  "private": true,
  "description": "Servly UI component workspace",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/servlyapp/servlyui.git"
  },
  "homepage": "https://github.com/servlyapp/servlyui#readme",
  "bugs": {
    "url": "https://github.com/servlyapp/servlyui/issues"
  },
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "typecheck": "npm run typecheck --workspaces",
    "pack:dry-run": "npm pack --dry-run -w @servlyui/number-input",
    "playground:install": "npm install --prefix playground/number-input-docs",
    "playground:dev": "npm --prefix playground/number-input-docs run dev",
    "playground:build": "npm --prefix playground/number-input-docs run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "typescript-eslint": "^8.63.0"
  }
}
